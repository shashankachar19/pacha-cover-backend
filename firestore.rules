// ============================================================
// firestore.rules — Pacha Cover v1.1
//
// Security model:
//   users         — owner read/write; leaderboard entry public read
//   adopted_spots — public spots readable by all; owner writes
//   verifications — owner read; owner create; immutable
//   ward_heat_data — authenticated read; backend-only write
//   leaderboard   — public read; Cloud Function write only
//
//   Feature 1: ar_models     — public read; admin write only
//   Feature 2: green_corridors — authenticated read; backend write only
//   Feature 3: carbon_simulations — owner read/write
//   Feature 4: voice_sessions — owner read/write
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    function isValidSpot() {
      let data = request.resource.data;
      return data.keys().hasAll(['user_id', 'spot_name', 'ward_name',
                                  'species_common_name', 'coordinates'])
          && data.user_id == request.auth.uid
          && data.spot_name is string
          && data.spot_name.size() >= 3;
    }

    // ── User Profiles ─────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:  if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // ── Adopted Spots ─────────────────────────────────────────────────────────
    match /adopted_spots/{spotId} {
      allow read:   if resource.data.is_public == true
                    || isOwner(resource.data.user_id);
      allow create: if isAuthenticated() && isValidSpot();
      allow update: if isOwner(resource.data.user_id);
      allow delete: if isOwner(resource.data.user_id);
    }

    // ── Verifications (immutable audit log) ───────────────────────────────────
    match /verifications/{verificationId} {
      allow read:   if isOwner(resource.data.user_id);
      allow create: if isAuthenticated()
                    && request.resource.data.user_id == request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }

    // ── Ward Heat Data (authenticated read; backend write) ────────────────────
    match /ward_heat_data/{wardId} {
      allow read:  if isAuthenticated();
      allow write: if false;
    }

    // ── Leaderboard (public read; Cloud Function write) ───────────────────────
    match /leaderboard/{userId} {
      allow read:  if true;
      allow write: if false;
    }

    // ── Feature 1: AR Models (public read; admin write) ───────────────────────
    match /ar_models/{speciesId} {
      // Public read — Flutter app downloads models before login
      allow read:  if true;
      // Only admin service account or admin custom-claim users can write
      allow write: if isAdmin();
    }

    // ── Feature 2: Green Corridors (auth read; backend write) ─────────────────
    match /green_corridors/{corridorId} {
      // Authenticated users can view corridors on the map
      allow read:  if isAuthenticated();
      // Only the backend service account (bypasses rules) can write
      allow write: if false;
    }

    // ── Feature 3: Carbon Simulations (owner read/write) ──────────────────────
    match /carbon_simulations/{simulationId} {
      allow read:   if isOwner(resource.data.user_id);
      allow create: if isAuthenticated()
                    && request.resource.data.user_id == request.auth.uid;
      allow update: if false;   // Simulations are immutable records
      allow delete: if isOwner(resource.data.user_id);
    }

    // ── Feature 4: Voice Sessions (owner read/write; no sensitive data stored) ─
    match /voice_sessions/{sessionId} {
      allow read:   if isOwner(resource.data.user_id);
      allow create: if isAuthenticated()
                    && request.resource.data.user_id == request.auth.uid;
      allow update: if false;
      allow delete: if isOwner(resource.data.user_id);
    }
  }
}
