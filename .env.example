# ============================================================
# Pacha (Green) Cover — .env.example  (v1.1 — Extended Features)
# Copy to .env and fill in real values before running.
# NEVER commit the real .env to version control.
# ============================================================

# ── Google Cloud Project ───────────────────────────────────────────────────────
GCP_PROJECT_ID="your-gcp-project-id"
GCP_REGION="asia-south1"                # Mumbai — closest to Bengaluru

# ── Firebase / Firestore ───────────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_PATH="./serviceAccountKey.json"
FIRESTORE_DATABASE_ID="(default)"

# ── Gemini API ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY_PRESCRIBE="your-gemini-api-key-for-prescriptions"
GEMINI_API_KEY_VERIFY="your-gemini-api-key-for-verification"
GEMINI_MODEL="gemini-2.5-flash"

# ── Google Earth Engine ────────────────────────────────────────────────────────
GEE_SERVICE_ACCOUNT="your-gee-sa@your-project.iam.gserviceaccount.com"
GEE_KEY_FILE_PATH="./gee_key.json"

# ── Google Cloud Storage (images + audio) ─────────────────────────────────────
GCS_BUCKET_NAME="pacha-cover-images"

# ── Application Settings ───────────────────────────────────────────────────────
APP_ENV="development"
SECRET_KEY="change-me-to-a-long-random-string"
ALLOWED_ORIGINS="http://localhost:3000,https://pacha-cover.web.app"

# ── Green Points ───────────────────────────────────────────────────────────────
POINTS_PER_VERIFICATION=50
POINTS_PER_ADOPTION=10

# ══════════════════════════════════════════════════════════════════════════════
# FEATURE 1 — Pacha Vision AR Metadata
# ══════════════════════════════════════════════════════════════════════════════

# Base URL of the GCS bucket (or CDN) hosting .glb 3D models and thumbnails
# Public bucket — no auth needed for Flutter to download models
AR_ASSETS_BASE_URL="https://storage.googleapis.com/pacha-cover-ar-assets"
AR_ASSETS_BUCKET="pacha-cover-ar-assets"

# Setup steps:
#   1. gsutil mb -l asia-south1 gs://pacha-cover-ar-assets
#   2. gsutil iam ch allUsers:objectViewer gs://pacha-cover-ar-assets
#   3. Upload models: gsutil cp *.glb gs://pacha-cover-ar-assets/models/
#   4. Upload thumbs: gsutil cp *.jpg gs://pacha-cover-ar-assets/thumbs/
#   5. Seed Firestore: POST /api/v1/assets/ar-model/seed (admin token)

# ══════════════════════════════════════════════════════════════════════════════
# FEATURE 2 — Green Corridor Clustering
# ══════════════════════════════════════════════════════════════════════════════

# Minimum verified trees within radius_m to qualify as Active Corridor
CORRIDOR_MIN_TREES=5
CORRIDOR_RADIUS_M=100.0

# Green Points awarded for the Corridor Creator badge
POINTS_CORRIDOR_BADGE=200

# Cloud Scheduler job setup (triggers audit daily at 02:00 IST):
#   gcloud scheduler jobs create http pacha-corridor-audit \
#     --location=asia-south1 \
#     --schedule="0 20 * * *" \
#     --time-zone="UTC" \
#     --uri="https://your-cloudrun-url/api/v1/corridors/audit" \
#     --http-method=POST \
#     --oidc-service-account-email=pacha-cover-sa@PROJECT.iam.gserviceaccount.com

# ══════════════════════════════════════════════════════════════════════════════
# FEATURE 3 — Carbon Credit & Tax Simulator
# ══════════════════════════════════════════════════════════════════════════════

# India voluntary carbon market rate (INR per tonne CO2)
# Range: 800–1200; default 1000 (mid-market 2024)
CARBON_CREDIT_RATE_INR_PER_TONNE=1000.0

# BBMP tax rebate simulation rule:
#   rebate_percent = floor(annual_co2_kg / TAX_REBATE_CO2_PER_PERCENT)
#   capped at TAX_REBATE_MAX_PERCENT
TAX_REBATE_CO2_PER_PERCENT=20.0
TAX_REBATE_MAX_PERCENT=20.0

# No extra GCP APIs needed — uses the existing Gemini API key

# ══════════════════════════════════════════════════════════════════════════════
# FEATURE 4 — Bhasha Vernacular Voice Interface
# ══════════════════════════════════════════════════════════════════════════════

# Default Speech-to-Text language (Kannada, India)
# Supported: kn-IN, hi-IN, ta-IN, te-IN, en-IN
SPEECH_DEFAULT_LANGUAGE_CODE="kn-IN"

# Translation pivot language (always English — Gemini works best in English)
TRANSLATION_PIVOT_LANGUAGE="en"

# Enable Text-to-Speech audio response (base64 MP3 in response body)
# false = text-only response (faster, lower cost)
# true  = adds ~500ms latency + Cloud TTS billing
VOICE_ENABLE_TTS_RESPONSE=false

# GCS bucket for temporary voice audio upload storage (auto-deleted after 7 days)
VOICE_AUDIO_BUCKET="pacha-cover-voice-audio"

# Required GCP APIs to enable for Feature 4:
#   gcloud services enable speech.googleapis.com
#   gcloud services enable translate.googleapis.com
#   gcloud services enable texttospeech.googleapis.com
#
# Required IAM roles for the Cloud Run service account:
#   roles/speech.editor          (Speech-to-Text)
#   roles/cloudtranslate.editor  (Translation API)
#   roles/texttospeech.editor    (Text-to-Speech, if TTS enabled)
#
# Grant roles:
#   gcloud projects add-iam-policy-binding PROJECT_ID \
#     --member="serviceAccount:pacha-cover-sa@PROJECT_ID.iam.gserviceaccount.com" \
#     --role="roles/speech.editor"
#   (repeat for cloudtranslate.editor and texttospeech.editor)
